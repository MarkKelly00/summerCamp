# =============================================================================
# Summer Camp 2026 environment template.
# Copy to `.env.local` for Next.js dev, and to `.env` for the legacy server.
# =============================================================================

# --- Required by the new Next.js app -----------------------------------------

# MongoDB Atlas connection string. Both the Next.js app and the legacy Express
# server can point at the same database during the strangler migration.
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/summercamp

# Session JWT signing secret for the new auth path. Generate with:
#   openssl rand -base64 48
AUTH_SECRET=replace-me-with-a-long-random-secret

# Public URL of the app, used for absolute links in emails/callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment label. development | production | test
NODE_ENV=development

# --- Still required by the legacy Express server under server/ ---------------

# Port the legacy Express server binds to. The Next app uses 3000 separately.
PORT=5001

# Legacy JWT secret used by the existing auth routes. Can match AUTH_SECRET or
# be rotated independently while both stacks coexist.
JWT_SECRET=replace-me-with-the-same-or-rotated-secret
